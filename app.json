{
  "expo": {
    "name": "connectiveApp",
    "slug": "connectiveApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/ProjectLogo.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      "expo-dev-client"
    ],
    "splash": {
      "image": "./assets/ProjectLogo.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/ProjectLogo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.anonymous.connectiveApp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
